# --- MongoDB Atlas ---
# Create a free cluster at https://www.mongodb.com/atlas, then:
# Database Access -> add a user; Network Access -> allow your IP (or 0.0.0.0/0 for dev)
# Connect -> Drivers -> copy the connection string and put it here.
MONGODB_URI="mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/khadim_hussain_metal_art?retryWrites=true&w=majority"

# --- Auth ---
# Any long random string. Generate one with:  openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"

# --- Default admin created by the seed (optional overrides) ---
SEED_ADMIN_EMAIL="admin@khma.com"
SEED_ADMIN_PASSWORD="admin123"

# --- Image uploads (production) ---
# Vercel Blob token. On Vercel, create a Blob store (Storage tab) and this is
# added automatically. For LOCAL uploads you can leave this empty (files save to
# public/uploads/). If set, all uploads go to Vercel Blob instead.
BLOB_READ_WRITE_TOKEN=""
